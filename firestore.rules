rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: /users/{userId}/expenses/{expenseId}
    // Fields: id, amount, category, accountId, date, note, type, toAccountId, attachments
    //
    // Collection: /users/{userId}/accounts/{accountId}
    // Fields: id, name, type, balance, icon, color
    //
    // Collection: /users/{userId}/categories/{categoryId}
    // Fields: id, name, icon, color, type
    //
    // Collection: /users/{userId}/budgets/{budgetId}
    // Fields: id, categoryId, amount, period
    //
    // Collection: /users/{userId}/settings/main
    // Fields: currencySymbol, currencyPosition, decimalPlaces, uiMode, passcode, reminderEnabled, currentThemeId
    //
    // Collection: /users/{userId}/activityLogs/{logId}
    // Fields: checked, value, updatedAt
    //
    // Collection: /users/{userId}/notes/{noteId}
    // Fields: id, date, content, updatedAt
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "shiponsarker2023@gmail.com" && request.auth.token.email_verified == true)
        );
    }

    function isValidString(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }

    function isValidNumber(val, min) {
      return val is number && val >= min;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /expenses/{expenseId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /accounts/{accountId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /categories/{categoryId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /budgets/{budgetId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /settings/{settingId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /activityLogs/{logId} {
        // Data validation for activity logs
        function isValidActivityLog(data) {
          return (data.checked is bool || data.value is number) &&
                 (!('updatedAt' in data) || data.updatedAt is timestamp);
        }

        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if (isOwner(userId) || isAdmin()) && isValidActivityLog(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /notes/{noteId} {
        function isValidNote(data) {
          return data.id is string &&
                 data.date is string &&
                 data.content is string &&
                 (!('updatedAt' in data) || data.updatedAt is timestamp);
        }

        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if (isOwner(userId) || isAdmin()) && isValidNote(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }
    }
  }
}
